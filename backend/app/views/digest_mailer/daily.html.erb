<div style="font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 560px; margin: 0 auto; color: #111;">
  <h1 style="font-size: 20px;">Hi <%= @user.name %>,</h1>
  <p>While you were away on <strong>it's an problem</strong>:</p>

  <% if @reply_count.positive? %>
    <h2 style="font-size: 16px;">New replies to your posts</h2>
    <ul>
      <% @notifications.select { |n| n.event == "reply" }.group_by(&:post).each do |post, group| %>
        <li>
          <strong><%= post.title %></strong> — <%= group.size %> new <%= "reply".pluralize(group.size) %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @helpful_count.positive? %>
    <h2 style="font-size: 16px;">Your replies helped people</h2>
    <ul>
      <% @notifications.select { |n| n.event == "helpful_mark" }.group_by(&:post).each do |post, group| %>
        <li>
          Your reply on <strong><%= post.title %></strong> earned <%= group.size %> helpful <%= "mark".pluralize(group.size) %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <p style="margin-top: 24px;">
    <a href="<%= @app_url %>" style="background: #0095f6; color: white; padding: 10px 18px; border-radius: 999px; text-decoration: none;">
      Open it's an problem
    </a>
  </p>

  <p style="color: #888; font-size: 12px; margin-top: 24px;">
    You're getting this because email digests are on. Turn them off in Settings → Notifications.
  </p>
</div>
