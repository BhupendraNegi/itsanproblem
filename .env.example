# itsanproblem dev stack config — copy to `.env` and adjust as needed.
# `docker compose` reads this file automatically. Secrets (JWT keys, etc.)
# belong in secrets/*.yml (SOPS), not here.

# ─── PostgreSQL (the `db` service) ───────────────────────────────────────
POSTGRES_USER=itsanproblem
POSTGRES_PASSWORD=itsanproblem
POSTGRES_DB=itsanproblem_development
POSTGRES_PORT=5432

# ─── Valkey (Redis-compatible; the `valkey` service) ─────────────────────
VALKEY_PORT=6379

# ─── Host port mappings ──────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ─── colima (macOS) — see bin/docker setup ───────────────────────────────
# Resource budget for the `itsaprom` colima profile. Sensible defaults are
# computed from host specs when unset.
# ITSAPROM_COLIMA_CPU=4
# ITSAPROM_COLIMA_MEMORY=6
# ITSAPROM_COLIMA_DISK=40
