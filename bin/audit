#!/usr/bin/env bash
#
# bin/audit — backend security scan: dependency CVEs (bundler-audit) + static
# analysis (Brakeman). Mirrors the `code` project's bin/audit. Run from anywhere
# in the repo. Same checks the Security CI workflow runs.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)/backend"
RUN=""; command -v mise >/dev/null 2>&1 && RUN="mise exec --"

echo "==> bundler-audit"
$RUN bundle exec bundler-audit check --update

echo
echo "==> Brakeman"
$RUN bin/brakeman --no-pager -q
